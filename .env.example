# Signer (single key reused across chains)
PRIVATE_KEY=

# RPCs — primary
SEPOLIA_RPC=https://ethereum-sepolia.publicnode.com
BASE_SEPOLIA_RPC=https://base-sepolia.publicnode.com
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
ZEROG_RPC=https://evmrpc-testnet.0g.ai

# RPCs — backup (Alchemy; 0G has no third-party alt — use primary)
# Format: https://{network}.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_BACKUP=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_SEPOLIA_RPC_BACKUP=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
UNICHAIN_SEPOLIA_RPC_BACKUP=https://unichain-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 0G Compute
ZEROG_PROVIDER_ADDRESS=
ZEROG_MODEL=deepseek-chat-v3-0324

# KeeperHub
KH_API_KEY=
KH_WORKFLOW_ID=

# ENS (Sepolia) — name owned by signer, used for ownership verification
ENS_NAME=argus.eth

# Namestone
NAMESTONE_API_KEY=
NAMESTONE_PARENT_DOMAIN=
NAMESTONE_SUBNAME=rebalancer

# kh CLI binary (optional; defaults to ~/go/bin/kh)
# KH_BIN=

# Uniswap (Unichain Sepolia)
UNIVERSAL_ROUTER=0xf70536b3bcc1bd1a972dc186a2cf84cc6da6be5d

# Vault (filled after deploy)
VAULT_ADDRESS=
