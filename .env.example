# Signer (single key reused across chains)
PRIVATE_KEY=

# RPCs — primary
SEPOLIA_RPC=https://ethereum-sepolia.publicnode.com
BASE_SEPOLIA_RPC=https://base-sepolia.publicnode.com
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
ZEROG_RPC=https://evmrpc-testnet.0g.ai

# RPCs — backup (Alchemy; 0G has no third-party alt — use primary)
# Format: https://{network}.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_RPC_BACKUP=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_SEPOLIA_RPC_BACKUP=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
UNICHAIN_SEPOLIA_RPC_BACKUP=https://unichain-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 0G Compute
# Testnet (chain 16602) providers — verified via scripts/verify-0g-provider.ts:
#   0xa48f01287233509FD694a22Bf840225062E67836  qwen/qwen-2.5-7b-instruct  TeeML
#   0x4b2a941929E39Adbea5316dDF2B9Bd8Ff3134389  qwen/qwen-image-edit-2511  TeeML
# deepseek-chat-v3-0324 is mainnet-only (chain 16661) and costs real OG.
ZEROG_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836
ZEROG_MODEL=qwen/qwen-2.5-7b-instruct
# scripts/setup-0g.ts tunables (units: OG). Defaults shown.
# ZEROG_LEDGER_AMOUNT=3
# ZEROG_LEDGER_MIN=0.5
# ZEROG_PROVIDER_AMOUNT=1
# ZEROG_PROVIDER_MIN=0.1

# KeeperHub
KH_API_KEY=
KH_WORKFLOW_ID=

# ENS (Sepolia) — name owned by signer, used for ownership verification
ENS_NAME=argus.eth

# Namestone
NAMESTONE_API_KEY=
NAMESTONE_PARENT_DOMAIN=
NAMESTONE_SUBNAME=rebalancer

# kh CLI binary (optional; defaults to ~/go/bin/kh)
# KH_BIN=

# Uniswap (Unichain Sepolia)
UNIVERSAL_ROUTER=0xf70536b3bcc1bd1a972dc186a2cf84cc6da6be5d
UNISWAP_QUOTER_V2=

# Quote dryrun (P5) — pair to probe via QuoterV2
QUOTE_TOKEN_IN=
QUOTE_TOKEN_OUT=
QUOTE_AMOUNT_IN=0.001
QUOTE_FEE=3000

# Fund-vault (P5) — token addresses on Unichain Sepolia
FUND_TOKEN_WETH=
FUND_TOKEN_USDC=

# Signal node (P4) — runtime
SIGNAL_PEER=
AXL_NODE_A_API=127.0.0.1:9002
ZEROG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Execution node (P6) — runtime
EXECUTION_PEER=
AXL_NODE_B_API=127.0.0.1:9003

# AXL wiring (P7) — used by scripts/{start-nodes.sh,test-round-trip.sh,measure-latency.ts}
# AXL_BIN: path to AXL daemon binary; default: ../04-axl-multinode/axl/node, then ../spike/node, then `axl` on PATH.
# AXL_BIN=
# Optional peer-ID overrides; if unset, scripts fetch from /topology.
# NODE_A_PEER_ID=
# NODE_B_PEER_ID=
# NODE_A_API=127.0.0.1:9002
# NODE_B_API=127.0.0.1:9003
# LATENCY_TRIALS=10
# LATENCY_LABEL=loopback
# EXEC_FEE_TIER=3000
# EXEC_SLIPPAGE_BPS=50
# EXEC_DEADLINE_SECONDS=300

# Vault (filled after deploy)
VAULT_ADDRESS=
